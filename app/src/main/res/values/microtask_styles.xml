<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Speech verification -->
    <style name="RatingLabel">
        <item name="android:textSize">@dimen/_9ssp</item>
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">0dp</item>
    </style>

    <style name="RatingButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/heading_color</item>
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="buttonTint">@color/primary_color</item>
        <item name="android:textSize">@dimen/_7ssp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:minWidth">0dp</item>
    </style>

    <style name="RatingButtonGroup">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_marginStart">@dimen/_1sdp</item>
        <item name="singleSelection">true</item>
        <item name="selectionRequired">true</item>

    </style>

    <!-- Sentence validation -->
    <style name="YesNoGroup">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="singleSelection">true</item>
        <item name="selectionRequired">true</item>
    </style>

    <style name="YesNoToggle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">@dimen/_8ssp</item>
    </style>


</resources>