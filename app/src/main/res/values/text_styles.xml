<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="HeadingTextStyle">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:textColor">@color/heading_color</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="EditTextTextStyle">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="NormalTextStyle">
        <item name="fontFamily">@font/poppins_regular</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/heading_color</item>
    </style>

    <style name="TimeTextStyle">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/heading_color</item>
        <item name="android:textSize">@dimen/_14sdp</item>
    </style>

    <style name="IOHeadingTextStyle">
        <item name="fontFamily">@font/poppins_semibold</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/heading_color</item>
        <item name="android:textSize">@dimen/_18sdp</item>
    </style>

    <style name="SubHeadingTextStyle">
        <item name="fontFamily">@font/poppins_medium</item>
        <item name="android:textColor">@color/heading_color</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextInputLayoutTextStyle" parent="Widget.MaterialComponents.TextInputLayout.FilledBox.Dense">
        <item name="fontFamily">@font/poppins_regular</item>
    </style>

</resources>