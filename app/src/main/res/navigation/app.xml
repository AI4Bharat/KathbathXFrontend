<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/app_nav_graph"
    app:startDestination="@id/splashScreenFragment">

    <fragment
        android:id="@+id/splashScreenFragment"
        android:name="com.ai4bharat.kathbath.ui.splashScreen.SplashScreenFragment"
        android:label="SplashScreenFragment"
        tools:layout="@layout/fragment_splash_screen">
        <action
            android:id="@+id/action_splashScreenFragment_to_login"
            app:destination="@id/login" />
        <action
            android:id="@+id/action_splashScreenFragment_to_dashboardActivity"
            app:destination="@id/dashboardActivity" />
    </fragment>
    <navigation
        android:id="@+id/oldLoginFlow"
        app:startDestination="@id/phoneNumberFragment">
        <fragment
            android:id="@+id/phoneNumberFragment"
            android:name="com.ai4bharat.kathbath.ui.onboarding.login.phone.PhoneNumberFragment"
            android:label="PhoneNumberFragment"
            tools:layout="@layout/fragment_phone_number" />
        <fragment
            android:id="@+id/OTPFragment"
            android:name="com.ai4bharat.kathbath.ui.onboarding.login.otp.OTPFragment"
            android:label="OTPFragment"
            tools:layout="@layout/fragment_otp" />
    </navigation>
    <navigation
        android:id="@+id/accessCodeFlow"
        app:startDestination="@id/accessCodeFragment">
        <fragment
            android:id="@+id/fileDownloadFragment"
            android:name="com.ai4bharat.kathbath.ui.onboarding.fileDownload.FileDownloadFragment"
            android:label="FileDownloadFragment"
            tools:layout="@layout/fragment_file_download" />
        <fragment
            android:id="@+id/accessCodeFragment"
            android:name="com.ai4bharat.kathbath.ui.onboarding.accesscode.AccessCodeFragment"
            android:label="AccessCodeFragment"
            tools:layout="@layout/fragment_access_code">
            <action
                android:id="@+id/action_accessCodeFragment_to_fileDownloadFragment"
                app:destination="@id/fileDownloadFragment"
                app:popUpTo="@id/accessCodeFragment"
                app:popUpToInclusive="true" />
        </fragment>
    </navigation>
    <fragment
        android:id="@+id/dashboardActivity"
        android:name="com.ai4bharat.kathbath.ui.dashboard.DashboardFragment"
        android:label="activity_dashboard"
        tools:layout="@layout/fragment_dashboard">
        <action
            android:id="@+id/action_dashboardActivity_to_speechDataMainFragment"
            app:destination="@id/speechDataMainFragment">
            <argument android:name="taskId" />
            <argument
                android:name="completed"
                app:argType="integer" />
            <argument
                android:name="total"
                app:argType="integer" />
        </action>
        <action
            android:id="@+id/action_dashboardActivity_to_speechVerificationFragment"
            app:destination="@id/speechVerificationFragment">
            <argument android:name="taskId" />
            <argument
                android:name="completed"
                app:argType="integer" />
            <argument
                android:name="total"
                app:argType="integer" />
        </action>
        <action
            android:id="@+id/action_dashboardActivity_to_login"
            app:destination="@id/login" />
        <action
            android:id="@+id/action_dashboardActivity_to_speechImageDataFragment"
            app:destination="@id/speechImageDataFragment">
            <argument android:name="taskId" />
            <argument
                android:name="completed"
                app:argType="integer" />
            <argument
                android:name="total"
                app:argType="integer" />
        </action>
        <action
            android:id="@+id/action_dashboardActivity_to_speechAudioDataFragment"
            app:destination="@id/speechAudioDataFragment">
            <argument android:name="taskId" />
            <argument
                android:name="completed"
                app:argType="integer" />
            <argument
                android:name="total"
                app:argType="integer" />
        </action>
        <action
            android:id="@+id/action_dashboardActivity_to_speechVerificationMultiModalFragment"
            app:destination="@id/speechVerificationMultiModalFragment">
            <argument android:name="taskId" />
            <argument
                android:name="completed"
                app:argType="integer" />
            <argument
                android:name="total"
                app:argType="integer" />
        </action>
    </fragment>
    <fragment
        android:id="@+id/speechDataMainFragment"
        android:name="com.ai4bharat.kathbath.ui.scenarios.speechData.SpeechDataMainFragment"
        android:label="SpeechDataMainFragment"
        tools:layout="@layout/microtask_speech_data">
        <argument
            android:name="taskId"
            app:argType="string" />
        <argument
            android:name="completed"
            app:argType="integer" />
        <argument
            android:name="total"
            app:argType="integer" />
        <action
            android:id="@+id/action_speechDataMainFragment_to_dashboardActivity"
            app:destination="@id/dashboardActivity"
            app:popUpTo="@id/dashboardActivity" />
    </fragment>
    <fragment
        android:id="@+id/speechVerificationFragment"
        android:name="com.ai4bharat.kathbath.ui.scenarios.speechVerification.SpeechVerificationFragment"
        android:label="SpeechVerificationFragment">
        <argument
            android:name="taskId"
            app:argType="string" />
        <argument
            android:name="completed"
            app:argType="integer" />
        <argument
            android:name="total"
            app:argType="integer" />
        <action
            android:id="@+id/action_speechVerificationFragment_to_dashboardActivity"
            app:destination="@id/dashboardActivity" />
    </fragment>
    <navigation
        android:id="@+id/login"
        app:startDestination="@id/crowdsourceLogin">
        <fragment
            android:id="@+id/crowdsourceLogin"
            android:name="com.ai4bharat.kathbath.ui.crowdsource.login.CrowdsourceLogin"
            android:label="fragment_crowdsource_login"
            tools:layout="@layout/fragment_crowdsource_login">
            <action
                android:id="@+id/action_crowdsourceLogin_to_crowdsourceRegistration"
                app:destination="@id/crowdsourceRegistration" />
            <action
                android:id="@+id/action_crowdsourceLogin_to_dashboardActivity"
                app:destination="@id/dashboardActivity" />
        </fragment>
        <fragment
            android:id="@+id/crowdsourceRegistration"
            android:name="com.ai4bharat.kathbath.ui.crowdsource.registration.CrowdsourceRegistration"
            android:label="fragment_crowdsource_registration"
            tools:layout="@layout/fragment_crowdsource_registration">
            <argument
                android:name="language"
                app:argType="string"
                android:defaultValue="hindi" />
            <action
                android:id="@+id/action_crowdsourceRegistration_to_crowdsourceLogin"
                app:destination="@id/crowdsourceLogin" />
        </fragment>
        <action
            android:id="@+id/action_global_dashboardActivity"
            app:destination="@id/dashboardActivity" />
    </navigation>
    <fragment
        android:id="@+id/speechImageDataFragment"
        android:name="com.ai4bharat.kathbath.ui.scenarios.speechImageData.SpeechImageDataFragment"
        android:label="fragment_speech_image_data"
        tools:layout="@layout/microtask_speech_image_data">
        <argument
            android:name="taskId"
            app:argType="string" />
        <argument
            android:name="completed"
            app:argType="integer" />
        <argument
            android:name="total"
            app:argType="integer" />
        <action
            android:id="@+id/action_speechImageDataFragment_to_dashboardActivity"
            app:destination="@id/dashboardActivity" />
    </fragment>
    <fragment
        android:id="@+id/speechAudioDataFragment"
        android:name="com.ai4bharat.kathbath.ui.scenarios.speechAudioData.SpeechAudioDataFragment"
        android:label="microtask_speech_audio_data"
        tools:layout="@layout/microtask_speech_audio_data">
        <argument
            android:name="taskId"
            app:argType="string" />
        <argument
            android:name="completed"
            app:argType="integer" />
        <argument
            android:name="total"
            app:argType="integer" />
        <action
            android:id="@+id/action_speechAudioDataFragment_to_dashboardActivity"
            app:destination="@id/dashboardActivity" />
    </fragment>
    <fragment
        android:id="@+id/speechVerificationMultiModalFragment"
        android:name="com.ai4bharat.kathbath.ui.scenarios.speechVerificationMultiModal.SpeechVerificationMultiModalFragment"
        android:label="SpeechVerificationMultiModalFragment">
        <argument
            android:name="taskId"
            app:argType="string" />
        <argument
            android:name="completed"
            app:argType="integer" />
        <argument
            android:name="total"
            app:argType="integer" />
        <action
            android:id="@+id/action_speechVerificationMultiModalFragment_to_dashboardActivity"
            app:destination="@id/dashboardActivity" />
    </fragment>
</navigation>
