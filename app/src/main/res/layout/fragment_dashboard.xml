<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dashBoardConstraint"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    tools:context=".ui.dashboard.DashboardFragment">

    <com.ai4bharat.karya.ui.views.KaryaToolbar
        android:id="@+id/appTb"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/_8sdp"
        app:titleText="@string/dashboard_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/syncCv"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_10sdp"
        android:layout_marginVertical="@dimen/_5sdp"
        android:clickable="true"
        android:elevation="@dimen/_8sdp"
        android:focusable="true"
        android:translationZ="@dimen/_8sdp"
        app:cardCornerRadius="@dimen/_5sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appTb">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/_15sdp"
            android:paddingVertical="@dimen/_10sdp">

            <TextView
                android:id="@+id/syncPromptTv"
                android:layout_width="match_parent"
                android:layout_height="@dimen/_20sdp"
                app:autoSizeMaxTextSize="@dimen/_30ssp"
                app:autoSizeMinTextSize="@dimen/_12ssp"
                app:autoSizeStepGranularity="@dimen/_2ssp"
                app:autoSizeTextType="uniform"
                android:gravity="center"
                android:text="@string/sync_prompt" />

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="@dimen/_20sdp"
                >

                <TextView
                    android:id="@+id/syncDuration"
                    android:layout_width="169dp"
                    android:layout_height="@dimen/_20sdp"
                    android:background="@color/c_very_light_green"
                    android:gravity="center"
                    android:text="[Uploaded : 0 mins]"
                    android:textColor="@color/c_black"
                    app:autoSizeMaxTextSize="@dimen/_10ssp"
                    app:autoSizeMinTextSize="@dimen/_5ssp"
                    app:autoSizeStepGranularity="@dimen/_2ssp"
                    app:autoSizeTextType="uniform" />

                <TextView
                    android:id="@+id/syncDurationOnPhone"
                    android:layout_width="@dimen/_170sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_weight="1"
                    android:background="#F49898"
                    android:gravity="center"
                    android:text="[On Phone : 0 mins]"
                    android:textColor="@color/c_black"
                    app:autoSizeMaxTextSize="@dimen/_10ssp"
                    app:autoSizeMinTextSize="@dimen/_5ssp"
                    app:autoSizeStepGranularity="@dimen/_2ssp"
                    app:autoSizeTextType="uniform" />
            </LinearLayout>
            <ProgressBar
                android:id="@+id/syncProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_7sdp"
                android:layout_marginBottom="@dimen/_5sdp"
                android:progress="0"
                android:progressTint="?colorSecondary"
                android:scaleY="2"
                android:visibility="gone" />

            <TextView
                android:id="@+id/syncErrorMessageTv"
                style="@style/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="This is an error message"
                android:textAlignment="center"
                android:visibility="gone" />

        </LinearLayout>


    </androidx.cardview.widget.CardView>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tasksRv"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/_10sdp"
        android:background="@color/c_very_light_grey"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingVertical="@dimen/_5sdp"
        android:scrollbars="none"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:layout_constraintBottom_toTopOf="@id/rupeesEarnedCl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/syncCv"
        app:layout_constraintVertical_bias="0.0"
        tools:itemCount="2"
        tools:listitem="@layout/item_task" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rupeesEarnedCl"
        android:layout_width="@dimen/_0sdp"
        android:layout_height="wrap_content"
        android:background="@color/c_light_grey"
        android:paddingHorizontal="@dimen/_15sdp"
        android:paddingVertical="@dimen/_5sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_40sdp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!--            <ImageView-->
            <!--                android:id="@+id/rupeeIconIv"-->
            <!--                android:layout_width="@dimen/_48sdp"-->
            <!--                android:layout_height="@dimen/_36sdp"-->
            <!--                android:background="@drawable/rupee_note" />-->

            <TextView
                android:id="@+id/textView2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Read"
                android:textColor="@color/c_black"
                android:textSize="@dimen/_15ssp" />

            <TextView
                android:id="@+id/rupeesEarnedTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_10sdp"
                android:textColor="@color/c_dark_green"
                android:textSize="@dimen/_15ssp"
                tools:text="0" />

            <TextView
                android:id="@+id/textView3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_10sdp"
                android:text="Extempore"
                android:textColor="@color/c_black"
                android:textSize="@dimen/_15ssp" />

            <TextView
                android:id="@+id/rupeesEarnedTv2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_10sdp"
                android:textColor="@color/c_red"
                android:textSize="@dimen/_15ssp"
                tools:text="0" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
