        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/microtaskMultiModalSpeechVerificationconversationsCl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/microtaskMultiModalSpeechVerificationcommentCl"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/microtaskMultiModalSpeechVerificationcommonCl4">
            <!--        app:layout_constraintBottom_toTopOf="@+id/microtaskMultiModalSpeechVerificationfluencyCl">-->

            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationsstTick"
                style="@style/RatingButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
                android:layout_marginRight="@dimen/_5ssp"
                android:checked="false"
                android:layoutDirection="rtl"
                android:padding='0dp'
                android:text="Single Sp Talking"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"

                />


            />


        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/microtaskMultiModalSpeechVerificationcommentCl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/microtaskMultiModalSpeechVerificationconversationsCl">
            <!--        app:layout_constraintBottom_toTopOf="@+id/microtaskMultiModalSpeechVerificationfluencyCl">-->


            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/microtaskMultiModalSpeechVerificationtextComment"
                style="@style/NormalTextStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="36dp"
                android:layout_marginEnd="8dp"
                android:hint="Comments"
                android:textSize="@dimen/_8sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/microtaskMultiModalSpeechVerificationotherTick"
                app:layout_constraintTop_toTopOf="parent">

            </com.google.android.material.textfield.TextInputEditText>

            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationotherTick"
                style="@style/RatingButton"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginStart="8dp"
                android:checked="false"
                android:padding="@dimen/_0sdp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />


        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/microtaskMultiModalSpeechVerificationbuttonGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingVertical="@dimen/_10sdp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <include
            android:id="@+id/microtaskMultiModalSpeechVerificationplaybackProgress"
            layout="@layout/microtask_common_playback_progress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <include
            android:id="@+id/microtaskMultiModalSpeechVerificationbackBtn"
            layout="@layout/microtask_common_back_button"
            android:layout_width="@dimen/_48sdp"
            android:layout_height="@dimen/_48sdp"
            android:layout_marginTop="16dp"
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@+id/microtaskMultiModalSpeechVerificationplayBtn"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/microtaskMultiModalSpeechVerificationplaybackProgress" />

        <ImageButton
            android:id="@+id/microtaskMultiModalSpeechVerificationplayBtn"
            android:layout_width="@dimen/_48sdp"
            android:layout_height="@dimen/_48sdp"
            android:background="@drawable/ic_speaker_enabled"
            app:layout_constraintBottom_toBottomOf="@+id/microtaskMultiModalSpeechVerificationbackBtn"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toStartOf="@+id/microtaskMultiModalSpeechVerificationnextBtnCv"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/microtaskMultiModalSpeechVerificationbackBtn"
            app:layout_constraintTop_toTopOf="@+id/microtaskMultiModalSpeechVerificationbackBtn"
            tools:ignore="MissingConstraints" />

        <include
            android:id="@+id/microtaskMultiModalSpeechVerificationnextBtnCv"
            layout="@layout/microtask_common_next_button"
            android:layout_width="@dimen/_48sdp"
            android:layout_height="@dimen/_48sdp"
            app:layout_constraintBottom_toBottomOf="@+id/microtaskMultiModalSpeechVerificationplayBtn"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/microtaskMultiModalSpeechVerificationplayBtn"
            app:layout_constraintTop_toTopOf="@+id/microtaskMultiModalSpeechVerificationplayBtn" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>