            app:layout_constraintBottom_toTopOf="@+id/microtaskMultiModalSpeechVerificationcommonCl4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/microtaskMultiModalSpeechVerificationcommonCl2">
            <!--        app:layout_constraintBottom_toTopOf="@+id/microtaskMultiModalSpeechVerificationfluencyCl">-->


            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationmisPronTick"
                style="@style/RatingButton"
                android:layout_width="@dimen/_58sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_5sdp"
