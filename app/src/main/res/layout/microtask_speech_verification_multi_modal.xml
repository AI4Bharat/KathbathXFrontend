                android:layout_width="@dimen/_50sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_1sdp"
                android:checked="false"
                android:layoutDirection="rtl"
                android:padding='0dp'
                android:text="Rep Cont."
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/microtaskMultiModalSpeechVerificationnotOnTopicTick"
                app:layout_constraintRight_toLeftOf="@+id/microtaskMultiModalSpeechVerificationlongPausesTick"
                app:layout_constraintTop_toTopOf="parent" />

            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationlongPausesTick"
                style="@style/RatingButton"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_1sdp"
                android:checked="false"
                android:layoutDirection="rtl"
                android:padding='0dp'
                android:text="Long Pause"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/microtaskMultiModalSpeechVerificationrepContentTick"
                app:layout_constraintRight_toLeftOf="@+id/microtaskMultiModalSpeechVerificationstretchingTick"
                app:layout_constraintTop_toTopOf="parent"

                />

            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationstretchingTick"
                style="@style/RatingButton"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_1sdp"

                android:checked="false"
                android:layoutDirection="rtl"
                android:padding='0dp'
                android:text="Stre tch"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/microtaskMultiModalSpeechVerificationlongPausesTick"
                app:layout_constraintRight_toLeftOf="@+id/microtaskMultiModalSpeechVerificationobjContTick"
                app:layout_constraintTop_toTopOf="parent"

                />

            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationobjContTick"
                style="@style/RatingButton"
                android:layout_width="@dimen/_50sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_1sdp"
                android:checked="false"
                android:layoutDirection="rtl"
                android:padding='0dp'
                android:text="Obj cont"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/microtaskMultiModalSpeechVerificationstretchingTick"
                app:layout_constraintRight_toRightOf="@+id/microtaskMultiModalSpeechVerificationechoTick"
                app:layout_constraintTop_toTopOf="parent" />

            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationechoTick"
                style="@style/RatingButton"
                android:layout_width="@dimen/_40sdp"
                android:layout_height="wrap_content"
                android:checked="false"
                android:layoutDirection="rtl"
                android:padding='0dp'
                android:text="Ec ho"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toRightOf="@+id/microtaskMultiModalSpeechVerificationobjContTick"
                app:layout_constraintRight_toRightOf="parent"
