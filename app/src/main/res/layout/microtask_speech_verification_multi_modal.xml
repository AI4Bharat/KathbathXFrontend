                app:layout_constraintTop_toTopOf="parent"

                />

            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationfactualInaccuracyTick"
                style="@style/RatingButton"
                android:layout_width="@dimen/_57sdp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_1sdp"
                android:checked="false"
                android:layoutDirection="rtl"
                android:padding='0dp'
                android:text="Fact Inacc."
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintRight_toLeftOf="@+id/microtaskMultiModalSpeechVerificationwrongLang"
                app:layout_constraintRight_toRightOf="parent"
