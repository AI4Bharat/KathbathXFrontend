                android:checked="false"
                android:layoutDirection="rtl"
                android:padding='0dp'
                android:text="mispronounce"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@+id/microtaskMultiModalSpeechVerificationskippingWordsTick"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.454" />

            <CheckBox
                android:id="@+id/microtaskMultiModalSpeechVerificationskippingWordsTick"
                style="@style/RatingButton"
                android:layout_width="@dimen/_56sdp"
                android:layout_height="wrap_content"
