<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:fillViewport="true"
    android:scrollbars="none"
    android:layout_height="match_parent"
    android:layout_width="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/frameLayout2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".ui.crowdsource.registration.CrowdsourceRegistration">

        <TextView
            android:id="@+id/crowdsourceRegistrationHeading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="24dp"
            style="@style/HeadingTextStyle"
            android:text="Register"
            android:textColor="@color/heading_color"
            android:textSize="@dimen/_24sdp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationNameLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:startIconDrawable="@drawable/ic_perm_identity"
            app:layout_constraintTop_toBottomOf="@+id/textView6">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/crowdsourceRegistrationName"
                android:layout_width="match_parent"
                style="@style/EditTextTextStyle"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:hint="Name"
                android:inputType="textPersonName" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/crowdsourceRegistrationgenderChipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationAgeLayout"
            app:selectionRequired="true"
            app:singleLine="true"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/maleChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:checked="true"
                android:text="Male" />

            <com.google.android.material.chip.Chip
                android:id="@+id/femaleChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="Female" />

            <com.google.android.material.chip.Chip
                android:id="@+id/othersChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checkable="true"
                android:text="Other" />
        </com.google.android.material.chip.ChipGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationAgeLayout"
            style="@style/TextInputLayoutTextStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:helperText="Please note that only adult(age 18 or more) can participate in this data collection."
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:startIconDrawable="@drawable/outline_calendar_month_24"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationNumberLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/crowdsourceRegistrationAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Age"
                style="@style/EditTextTextStyle"
                android:maxLines="1"
                android:inputType="numberDecimal" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/crowdsourceRegistrationButton"
            style="@style/submitButton"
            android:background="@drawable/rounded_button_background"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:layout_marginBottom="16dp"
            android:outlineProvider="none"
            android:text="Register"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textViewcrowdsourceRegistrationStatus" />


        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationLanguageLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:hint="Language"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:boxStrokeColor="@color/primary_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationGenderError"
            app:startIconDrawable="@drawable/language_icon">

            <AutoCompleteTextView
                android:id="@+id/crowdsourceRegistrationLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/EditTextTextStyle"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationStateLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:hint="Native State"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:boxStrokeColor="@color/primary_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView7"
            app:startIconDrawable="@drawable/baseline_explore_24">

            <AutoCompleteTextView
                android:id="@+id/crowdsourceRegistrationState"
                android:layout_width="match_parent"
                style="@style/EditTextTextStyle"
                android:maxLines="1"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationDistrictLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:hint="Native District"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:boxStrokeColor="@color/primary_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationStateLayout"
            app:startIconDrawable="@drawable/baseline_explore_24">

            <AutoCompleteTextView
                android:id="@+id/crowdsourceRegistrationDistrict"
                android:layout_width="match_parent"
                android:maxLines="1"
                style="@style/EditTextTextStyle"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationMostTimeSpendLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:hint="Spent most of your life in"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:boxStrokeColor="@color/primary_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationDistrictLayout"
            app:startIconDrawable="@drawable/baseline_explore_24">

            <AutoCompleteTextView
                android:id="@+id/crowdsourceRegistrationMostTimeSpend"
                android:layout_width="match_parent"
                style="@style/EditTextTextStyle"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>


        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationJobTypeLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:hint="Job Type"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:boxStrokeColor="@color/primary_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView8"
            app:startIconDrawable="@drawable/job_icon">

            <AutoCompleteTextView
                android:id="@+id/crowdsourceRegistrationJobType"
                android:layout_width="match_parent"
                android:maxLines="1"
                style="@style/EditTextTextStyle"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationEducationLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:hint="Education"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:boxStrokeColor="@color/primary_color"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationJobTypeLayout"
            app:startIconDrawable="@drawable/education">

            <AutoCompleteTextView
                android:id="@+id/crowdsourceRegistrationEducation"
                android:layout_width="match_parent"
                android:inputType="textMultiLine"
                style="@style/EditTextTextStyle"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationNumberLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationNameLayout"
            app:startIconDrawable="@drawable/outline_phone_24">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/crowdsourceRegistrationNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone Number"
                style="@style/EditTextTextStyle"
                android:maxLines="1"
                android:inputType="phone" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationOccupationLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:startIconDrawable="@drawable/baseline_computer_24"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationEducationLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/crowdsourceRegistrationOccupation"
                android:layout_width="match_parent"
                android:maxLines="1"
                style="@style/EditTextTextStyle"
                android:layout_height="wrap_content"
                android:hint="Occupation" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/crowdsourceRegistrationReferrelCodeLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            android:theme="@style/CustomTextInputLayout"
            app:boxBackgroundColor="@color/c_white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:startIconDrawable="@drawable/outline_groups_24"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationOccupationLayout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/crowdsourceRegistrationReferralCode"
                android:layout_width="match_parent"
                android:maxLines="1"
                style="@style/EditTextTextStyle"
                android:layout_height="wrap_content"
                android:hint="Referral Code" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/crowdsourceRegistrationGenderError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:textColor="#FF0000"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationgenderChipGroup" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/crowdsourceRegistrationConsentLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationReferrelCodeLayout">

            <TextView
                android:id="@+id/crowdsourceRegistrationReadConsent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Please click, read and accept the consent form"
                app:layout_constraintBottom_toBottomOf="@+id/crowdsourceRegistrationConsent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/crowdsourceRegistrationConsent"
                app:layout_constraintTop_toTopOf="@+id/crowdsourceRegistrationConsent" />

            <CheckBox
                android:id="@+id/crowdsourceRegistrationConsent"
                style="@style/RatingButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/primary_color"
                android:clickable="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/crowdsourceRegistrationConsentFormError"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:textAlignment="center"
            android:textColor="@color/c_red"
            app:layout_constraintEnd_toEndOf="@+id/crowdsourceRegistrationConsentLayout"
            app:layout_constraintStart_toStartOf="@+id/crowdsourceRegistrationConsentLayout"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationConsentLayout" />

        <ProgressBar
            android:id="@+id/crowdsourceRegistrationProgressbar"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/primary_color"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textViewcrowdsourceRegistrationStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginEnd="32dp"
            android:textAlignment="center"
            android:textColor="@color/c_red"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationConsentFormError" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/EditTextTextStyle"
            android:text="Welcome to Kathbath!"
            android:textColor="@color/heading_color"
            app:layout_constraintStart_toStartOf="@+id/crowdsourceRegistrationHeading"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationHeading" />

        <TextView
            android:id="@+id/textView6"
            style="@style/SubHeadingTextStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="32dp"
            android:text="Participant Basic Information"
            android:textColor="@color/heading_color"
            android:textSize="@dimen/_14sdp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="32dp"
            style="@style/SubHeadingTextStyle"
            android:layout_marginEnd="32dp"
            android:text="Location Information "
            android:textColor="@color/heading_color"
            android:textSize="@dimen/_14sdp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationLanguageLayout" />

        <TextView
            android:id="@+id/textView8"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="32dp"
            android:layout_marginEnd="32dp"
            style="@style/SubHeadingTextStyle"
            android:textStyle="bold"
            android:textSize="@dimen/_14sdp"
            android:text="Education and Job Information"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/crowdsourceRegistrationMostTimeSpendLayout" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
